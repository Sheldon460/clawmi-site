{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "@chrome-devtools/mcp-server"
      ],
      "env": {
        "CHROME_PATH": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
        "CHROME_USER_DATA_DIR": "${HOME}/.chrome-devtools-mcp",
        "CHROME_HEADLESS": "false"
      }
    },
    "mi-ma-arch-website": {
      "command": "node",
      "args": [
        "./server.js"
      ],
      "env": {
        "PORT": "3456",
        "WEBSITE_URL": "http://localhost:3000"
      }
    }
  }
}
