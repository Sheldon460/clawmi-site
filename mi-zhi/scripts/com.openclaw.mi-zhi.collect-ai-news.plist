<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 任务标签 -->
    <key>Label</key>
    <string>com.openclaw.mi-zhi.collect-ai-news</string>
    
    <!-- 要执行的程序 -->
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/node</string>
        <string>/Volumes/My house/Users/Sheldon/.openclaw/workspace/mi-zhi/scripts/collect-ai-news.js</string>
    </array>
    
    <!-- 工作目录 -->
    <key>WorkingDirectory</key>
    <string>/Volumes/My house/Users/Sheldon/.openclaw/workspace/mi-zhi</string>
    
    <!-- 每天 7:30 执行 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>
    
    <!-- 标准输出日志 -->
    <key>StandardOutPath</key>
    <string>/Volumes/My house/Users/Sheldon/.openclaw/workspace/mi-zhi/logs/ai-news-collect.log</string>
    
    <!-- 标准错误日志 -->
    <key>StandardErrorPath</key>
    <string>/Volumes/My house/Users/Sheldon/.openclaw/workspace/mi-zhi/logs/ai-news-collect.err</string>
    
    <!-- 环境变量 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/Sheldon</string>
    </dict>
    
    <!-- 保持运行环境 -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
