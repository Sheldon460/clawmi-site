// This is your Prisma schema file for ClawdBob Brand Website
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// User Authentication & Profile
// ========================================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  username      String?   @unique
  avatar        String?
  bio           String?
  role          UserRole  @default(USER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  conversations Conversation[]
  orders        Order[]
  guestbookEntries GuestbookEntry[]
  comments      Comment[]
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

// ========================================
// AI Conversations & Chat History
// ========================================
model Conversation {
  id            String    @id @default(cuid())
  userId        String?
  title         String?
  isPublic      Boolean   @default(false)
  shareSlug     String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      Message[]
  
  @@index([userId])
  @@index([shareSlug])
  @@map("conversations")
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  role            MessageRole
  content         String   @db.Text
  model           String?  // AI model used (e.g., "gpt-4", "claude-3")
  tokensUsed      Int?     // Token count for this message
  audioUrl        String?  // URL to TTS audio if voice is used
  createdAt       DateTime @default(now())
  
  // Relations
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ========================================
// Shop & Products
// ========================================
model Product {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  description   String       @db.Text
  shortDesc     String?
  price         Decimal      @db.Decimal(10, 2)
  salePrice     Decimal?     @db.Decimal(10, 2)
  type          ProductType
  status        ProductStatus @default(DRAFT)
  image         String?      // Main product image
  downloadUrl   String?      // For digital products
  licenseKey    String?      // License activation key
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  // Relations
  orderItems    OrderItem[]
  
  @@index([status])
  @@index([type])
  @@map("products")
}

enum ProductType {
  DIGITAL      // Digital downloads, software
  SERVICE      // Services, consultations
  SUBSCRIPTION // Recurring subscription
  SKILL_PACK   // Skill packs like on hireaclaw.ai
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  OUT_OF_STOCK
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  totalAmount     Decimal     @db.Decimal(10, 2)
  currency        String      @default("USD")
  paymentMethod   String?     // stripe, alipay, wechat
  paymentIntentId String?     // Stripe payment intent ID
  paidAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  
  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  unitPrice     Decimal @db.Decimal(10, 2)
  totalPrice    Decimal @db.Decimal(10, 2)
  licenseKey    String? // For digital products
  downloadCount Int     @default(0)
  
  // Relations
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id])
  
  @@map("order_items")
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
}

// ========================================
// Guestbook & Comments
// ========================================
model GuestbookEntry {
  id            String          @id @default(cuid())
  userId        String?
  authorName    String
  authorEmail   String?
  authorWebsite String?
  content       String          @db.Text
  isPublic      Boolean         @default(true)
  isApproved    Boolean         @default(false)
  likes         Int             @default(0)
  parentId      String?         // For nested replies
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  // Relations
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  parent        GuestbookEntry? @relation("EntryReplies", fields: [parentId], references: [id])
  replies       GuestbookEntry[] @relation("EntryReplies")
  
  @@index([isPublic, isApproved])
  @@index([parentId])
  @@map("guestbook_entries")
}

// Comments on shared conversations
model Comment {
  id            String   @id @default(cuid())
  userId        String
  conversationId String?
  content       String   @db.Text
  likes         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@map("comments")
}

// ========================================
// Site Settings & Analytics
// ========================================
model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
  
  @@map("site_settings")
}

model Analytics {
  id        String   @id @default(cuid())
  page      String
  referrer  String?
  userAgent String?
  ipAddress String?
  country   String?
  createdAt DateTime @default(now())
  
  @@index([page])
  @@index([createdAt])
  @@map("analytics")
}
