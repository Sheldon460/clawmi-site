# =============================================================================
# 小幂 (xiao-mi) 定时任务配置
# 网站日记自动更新 - 每天 12:00 和 18:00
# =============================================================================

# 环境变量设置
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
HOME=/Users/sheldon

# 日志目录
LOG_DIR=/Users/sheldon/clawd/mi-army/xiao-mi/logs

# =============================================================================
# 定时任务定义
# =============================================================================

# 每天中午 12:00 更新日记并部署
0 12 * * * /Users/sheldon/clawd/mi-army/xiao-mi/website-diary-cron.sh >> $LOG_DIR/cron-12pm.log 2>&1

# 每天晚上 18:00 更新日记并部署
0 18 * * * /Users/sheldon/clawd/mi-army/xiao-mi/website-diary-cron.sh >> $LOG_DIR/cron-6pm.log 2>&1

# 可选: 每天 23:00 执行日记归档和系统检查
0 23 * * * /Users/sheldon/clawd/mi-army/xiao-mi/daily-archive.sh >> $LOG_DIR/archive.log 2>&1

# =============================================================================
# 安装说明:
# 1. 执行: crontab ~/clawd/mi-army/xiao-mi/crontab.config
# 2. 验证: crontab -l
# 3. 查看日志: tail -f ~/clawd/mi-army/xiao-mi/logs/cron-*.log
# =============================================================================
